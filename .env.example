# ----------------------------
# 无影 / 阿里云
# ----------------------------
# 无论是单机模式还是设备池模式，通过 ADB 连接云手机都仍然需要：
# 1. 云手机实例已绑定密钥对
# 2. 本地存在该密钥对对应的 adbkey 文件
# 如果 5 台手机都绑定同一个密钥对，继续统一使用同一组全局配置即可。
# AK/SK / Region / Endpoint / KeyPair 主要用于 OpenAPI 启动实例、开启 ADB、自动绑定密钥对。
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
WUYING_REGION_ID=cn-shanghai
WUYING_ENDPOINT=
WUYING_INSTANCE_IDS=acp-xxxxxxxxxxxxxxxx
WUYING_KEY_PAIR_ID=
WUYING_AUTO_ATTACH_KEY_PAIR=false

# ----------------------------
# ADB / 设备池
# ----------------------------
# ADB_VENDOR_KEYS 指向同一个 adbkey 文件即可，设备池里的多台手机共享这一份。
ADB_PATH=adb
ADB_VENDOR_KEYS=
ADB_CONNECT_TIMEOUT_SECONDS=30
ADB_READY_TIMEOUT_SECONDS=120
WUYING_START_ADB_VIA_API=false
WUYING_MANUAL_ADB_ENDPOINT=
DEVICE_POOL_FILE=config/device_pool.json
DEVICE_LEASE_DIR=.runtime/device_leases
DEVICE_LEASE_TTL_SECONDS=7200

# ----------------------------
# API 服务 / 回调
# ----------------------------
SCRAPER_API_KEY=
CRAWLER_CALLBACK_URL=http://geo-watcher-backend:3005/api/integrations/crawler/uploads
CRAWLER_CALLBACK_API_KEY=
# 可不填；默认会从 CRAWLER_CALLBACK_URL=/uploads 推导为同目录 /progress。
CRAWLER_PROGRESS_URL=
CRAWLER_PROGRESS_API_KEY=
CRAWLER_RECORD_TIMEOUT_SECONDS=300
CRAWLER_BATCH_TIMEOUT_SECONDS=3600
CRAWLER_BATCH_MAX_WORKERS=5
BATCH_OUTPUT_DIR=data/batches
WUYING_SHARED_NETWORK=wuying-crawler-shared
WUYING_CRAWLER_ALIAS=wuying-crawler

# ----------------------------
# 平台高级覆盖项
# ----------------------------
# 默认情况下不需要配置。只有你要覆盖包名 / 启动页 / 超时 / 选择器时才加。
# 指标计算如果要自动启用，至少还需要配置：
# PIPELINE_LLM_API_KEY=...
# PIPELINE_METRIC_KEYWORD=你的品牌名
# PIPELINE_METRIC_DETECT_TYPE=rank
# 例如：
# DOUBAO_PACKAGE_NAME=com.larus.nova
# DOUBAO_LAUNCH_ACTIVITY=
# DOUBAO_RESPONSE_TIMEOUT_SECONDS=120
PIPELINE_LLM_API_KEY=89df43be-daf3-4936-839b-c83aaf92a7a7
PIPELINE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PIPELINE_LLM_MODEL=doubao-seed-1-6-lite-251015
PIPELINE_METRIC_KEYWORD=
PIPELINE_METRIC_DETECT_TYPE=rank
